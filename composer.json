{
    "name": "candycore/candy-shine",
    "description": "PHP port of charmbracelet/glamour — Markdown → ANSI renderer with word-wrap, OSC 8 hyperlinks, syntax highlighting, and 8 stock themes (ansi/plain/dark/light/notty/dracula/tokyo-night/pink).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "markdown", "renderer", "ansi", "tui", "terminal",
        "glamour", "commonmark", "syntax-highlighting",
        "candycore"
    ],
    "homepage": "https://github.com/detain/CandyCore",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/detain/CandyCore/issues",
        "source": "https://github.com/detain/CandyCore",
        "docs":   "https://github.com/detain/CandyCore/blob/master/CONVERSION.md"
    },
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-sprinkles": "@dev",
        "league/commonmark":         "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Shine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Shine\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
